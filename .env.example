# =================================================================
# MSRTC Platform - Environment Variables Template
# =================================================================
# Copy this file to `.env` for local development, or use these
# keys in your Staging/Production environments on Render.
# =================================================================

# -----------------------------------------------------------------
# 1. API Gateways & Service URLs
# -----------------------------------------------------------------
# For frontend apps. In Render, NEXT_PUBLIC_API_URL is automatically 
# populated by the render.yaml blueprint linking the two services.
NEXT_PUBLIC_API_URL=http://localhost:10000

# -----------------------------------------------------------------
# 2. Database & Infrastructure
# -----------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/msrtc_db
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------
# 3. Security & Auth (Keep these secret in production!)
# -----------------------------------------------------------------
JWT_SECRET=super_secret_jwt_key_change_me_in_prod
SESSION_SECRET=super_secret_session_key_change_me_in_prod
ADMIN_API_KEY=admin_secret_key_123

# -----------------------------------------------------------------
# 4. Third-Party Integrations
# -----------------------------------------------------------------
# Payment Gateway (e.g., Razorpay/Stripe)
PAYMENT_GATEWAY_KEY=test_pg_key_123
PAYMENT_WEBHOOK_SECRET=test_wh_secret_123

# Maps & Location (e.g., Google Maps, Mapbox)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
